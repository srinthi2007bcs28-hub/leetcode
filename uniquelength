#include <string.h>

int countPalindromicSubsequence(char *s) {
    int n = strlen(s);
    int count = 0;

    for (char ch = 'a'; ch <= 'z'; ch++) {
        int first = -1, last = -1;

        // Find first occurrence
        for (int i = 0; i < n; i++) {
            if (s[i] == ch) {
                first = i;
                break;
            }
        }

        // Find last occurrence
        for (int i = n - 1; i >= 0; i--) {
            if (s[i] == ch) {
                last = i;
                break;
            }
        }

        if (first != -1 && first < last) {
            int seen[26] = {0};

            for (int i = first + 1; i < last; i++) {
                if (!seen[s[i] - 'a']) {
                    seen[s[i] - 'a'] = 1;
                    count++;
                }
            }
        }
    }

    return count;
}
