#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int compare(const void *a, const void *b) {
    char s1[20], s2[20];
    char comb1[40], comb2[40];


    sprintf(s1, "%d", *(const int*)a);
    sprintf(s2, "%d", *(const int*)b);

    strcpy(comb1, s1); strcat(comb1, s2);
    strcpy(comb2, s2); strcat(comb2, s1);

    return strcmp(comb2, comb1);
}

char* largestNumber(int* nums, int numsSize) {
    qsort(nums, numsSize, sizeof(int), compare);

    if (nums[0] == 0) {
        char* zero = (char*)malloc(2 * sizeof(char));
        strcpy(zero, "0");
        return zero;
    }

    char* result = (char*)malloc(1200 * sizeof(char));
    result[0] = '\0'; 
    for (int i = 0; i < numsSize; i++) {
        char temp[20];
        sprintf(temp, "%d", nums[i]);
        strcat(result, temp);
    }

    return result;
}
